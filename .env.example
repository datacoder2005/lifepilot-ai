# LifePilot AI - Environment Variables Template

# Gemini API Key from Google AI Studio (https://aistudio.google.com/)
# Optional: If omitted, the application runs in a high-fidelity Sandbox/Mock mode.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Supabase configuration if you choose to sync your local state to the cloud.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
